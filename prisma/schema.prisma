generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  name              String
  phone             String?
  role              Role      @default(CUSTOMER)
  emailVerified     Boolean   @default(false)
  verifyToken       String?
  verifyTokenExpiry DateTime?
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  orders    Order[]
  addresses Address[]

  @@index([email])
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  name       String
  street     String
  city       String
  state      String
  postalCode String
  country    String  @default("México")
  isDefault  Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

model Product {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String
  fullDescription String @default("")
  benefits     String[] @default([])
  application  String   @default("")
  presentation String
  type         String
  category     String
  image        String
  priceMxn     Int      // centavos
  stock        Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orderItems OrderItem[]

  @@index([slug])
  @@index([category])
  @@index([active])
}

model Order {
  id               String      @id @default(cuid())
  folio            String      @unique  // BIO-ORD-000001
  userId           String
  addressId        String?
  status           OrderStatus @default(PENDING)
  totalMxn         Int         // centavos — calculado en backend
  stripeSessionId  String?     @unique
  stripePaymentId  String?
  shippingName     String
  shippingStreet   String
  shippingCity     String
  shippingState    String
  shippingPostal   String
  shippingCountry  String      @default("México")
  customerEmail    String
  customerPhone    String?
  notes            String?
  paidAt           DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user      User        @relation(fields: [userId], references: [id])
  address   Address?    @relation(fields: [addressId], references: [id])
  items     OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([stripeSessionId])
  @@index([folio])
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  productId  String
  name       String // snapshot
  image      String // snapshot
  priceMxn   Int    // snapshot centavos
  quantity   Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// Secuencia global para folios — solo 1 row con id=1
model OrderCounter {
  id    Int @id @default(1)
  count Int @default(0)
}

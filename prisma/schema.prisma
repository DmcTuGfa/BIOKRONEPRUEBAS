generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum ShippingStatus {
  PENDIENTE
  PREPARANDO
  ENVIADO
  EN_TRANSITO
  ENTREGADO
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  name              String
  phone             String?
  role              Role      @default(CUSTOMER)
  emailVerified     Boolean   @default(false)
  verifyToken       String?
  verifyTokenExpiry DateTime?
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  orders    Order[]
  addresses Address[]

  @@index([email])
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  name       String
  street     String
  city       String
  state      String
  postalCode String
  country    String  @default("México")
  isDefault  Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

model Product {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String
  fullDescription String   @default("")
  benefits        String[] @default([])
  application     String   @default("")
  presentation    String
  type            String
  category        String
  image           String
  priceMxn        Int
  stock           Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orderItems OrderItem[]

  @@index([slug])
  @@index([category])
  @@index([active])
}

model Order {
  id               String      @id @default(cuid())
  folio            String      @unique
  userId           String
  addressId        String?
  status           OrderStatus @default(PENDING)
  totalMxn         Int
  stripeSessionId  String?     @unique
  stripePaymentId  String?
  shippingName     String
  shippingStreet   String
  shippingCity     String
  shippingState    String
  shippingPostal   String
  shippingCountry  String      @default("México")
  customerEmail    String
  customerPhone    String?
  notes            String?
  trackingNumber   String?        // guía de envío
  trackingUrl      String?        // URL directa de rastreo
  shippingCarrier  String?        // paquetería (DHL, FedEx, Estafeta…)
  shippingStatus   ShippingStatus @default(PENDIENTE)
  paidAt           DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user    User       @relation(fields: [userId], references: [id])
  address Address?   @relation(fields: [addressId], references: [id])
  items   OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([stripeSessionId])
  @@index([folio])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  name      String
  image     String
  priceMxn  Int
  quantity  Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model OrderCounter {
  id    Int @id @default(1)
  count Int @default(0)
}

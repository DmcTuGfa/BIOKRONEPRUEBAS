# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://tudominio.com

# ─── Neon Postgres ────────────────────────────────────────────────────────────
# Obtener en: https://console.neon.tech → Tu proyecto → Connection string
# La URL de conexión "pooled" (pgBouncer) es para el runtime
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.us-east-2.aws.neon.tech/biokrone?sslmode=require&pgbouncer=true&connect_timeout=15
# La URL "directa" (sin pooler) es para las migraciones de Prisma
DIRECT_URL=postgresql://user:password@ep-xxx-yyy.us-east-2.aws.neon.tech/biokrone?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Genera uno seguro: openssl rand -hex 64
JWT_SECRET=cambiar-por-string-aleatorio-muy-largo-minimo-64-caracteres

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Obtener en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Obtener al configurar webhook en: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Obtener en: https://resend.com → API Keys (gratis hasta 3,000/mes)
RESEND_API_KEY=re_...
EMAIL_FROM=BIOKRONE <noreply@tudominio.com>

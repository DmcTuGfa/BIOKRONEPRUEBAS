# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://tudominio.railway.app

# ─── Neon Postgres ────────────────────────────────────────────────────────────
# Usa la URL pooled de Neon para Railway / Prisma runtime.
# Agrega al final: &pgbouncer=true&connect_timeout=15
DATABASE_URL=postgresql://user:password@ep-xxx-yyy-pooler.us-east-2.aws.neon.tech/biokrone?sslmode=require&channel_binding=require&pgbouncer=true&connect_timeout=15

# ─── Auth JWT ─────────────────────────────────────────────────────────────────
# Genera con: openssl rand -hex 64
JWT_SECRET=pon-aqui-un-string-muy-largo-y-aleatorio-minimo-64-caracteres-por-favor

# ─── Stripe ───────────────────────────────────────────────────────────────────
# IMPORTANTE: no mezclar claves test con live.
# Si usas pruebas: sk_test + pk_test
# Si usas producción: sk_live + pk_live
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# dashboard.stripe.com → Developers → Webhooks → tu endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email con Resend (opcional) ──────────────────────────────────────────────
# Si tu app está con autorización automática sin confirmación, esto puede agregarse después.
RESEND_API_KEY=re_...
EMAIL_FROM=BIOKRONE <noreply@tudominio.com>

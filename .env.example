# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://tudominio.railway.app

# ─── Neon Postgres ────────────────────────────────────────────────────────────
# neon.tech → Tu proyecto → Dashboard → Connection string
#
# DATABASE_URL  = URL pooled (para el app en runtime, usa pgBouncer)
# DIRECT_URL    = URL directa (para migraciones de Prisma)
#
# Formato:
#   postgresql://USER:PASSWORD@ep-NOMBRE.REGION.aws.neon.tech/DBNAME
#
DATABASE_URL=postgresql://user:password@ep-xxx-yyy.us-east-2.aws.neon.tech/biokrone?sslmode=require&pgbouncer=true&connect_timeout=15
DIRECT_URL=postgresql://user:password@ep-xxx-yyy.us-east-2.aws.neon.tech/biokrone?sslmode=require

# ─── Auth JWT ─────────────────────────────────────────────────────────────────
# Genera con: openssl rand -hex 64
JWT_SECRET=pon-aqui-un-string-muy-largo-y-aleatorio-minimo-64-caracteres-por-favor

# ─── Stripe ───────────────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# dashboard.stripe.com → Developers → Webhooks → tu endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email con Resend ─────────────────────────────────────────────────────────
# resend.com → API Keys  (gratis hasta 3,000 emails/mes)
RESEND_API_KEY=re_...
EMAIL_FROM=BIOKRONE <noreply@tudominio.com>
